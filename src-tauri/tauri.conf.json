{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helm",
  "version": "0.1.0",
  "identifier": "com.helm.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Helm",
        "width": 1320,
        "height": 860,
        "minWidth": 860,
        "minHeight": 520,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
